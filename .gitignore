# Xcode - ignore generated/user-specific files, but NOT the project itself
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint
DerivedData/
build/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Ignore the SPM-generated Xcode workspace (not our real project)
**/.swiftpm/xcode/

# Swift Package Manager
.build/
Packages/

# CocoaPods (if ever used)
Pods/

# Secrets - NEVER commit
Secrets.xcconfig
*.xcconfig

# Environment
.env
.env.*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Archives
*.xcarchive

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# Temporary
*.tmp
*.temp
